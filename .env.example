# Copy this file to .env and tune values if needed.

# Scene timing. Lower values make each scene shorter.
REEL_SCENE_MIN_SECONDS=4.8
REEL_SCENE_MAX_SECONDS=8.5
REEL_SCENE_BASE_SECONDS=0.9
REEL_SECONDS_PER_WORD=0.28
REEL_DURATION_SCALE=1

# Motion quality. 3 is smoother than 1, but renders slower.
# Use 2 if your machine struggles, 4 if you want more precision.
REEL_MOTION_OVERSAMPLE=3

# Optional scene selection. Leave commented to render all scenes.
# Pick exact scene numbers:
# REEL_SCENES=1,3,7
#
# Pick mixed ranges and numbers:
# REEL_SCENES=1-3,8
#
# Pick one continuous range:
# REEL_SCENE_RANGE=1-5
#
# Render only the first N scenes after other filters:
# REEL_SCENE_LIMIT=3
